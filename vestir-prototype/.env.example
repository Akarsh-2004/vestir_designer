# Inference (Gemini) — required for /api/items/infer unless you rely on fallbacks
GEMINI_API_KEY=

# Local fashion embeddings — point at embedding-sidecar (see embedding-sidecar/README.md)
EMBEDDING_SIDECAR_URL=http://127.0.0.1:8010

# Optional vision YOLO sidecar (if used)
# VISION_SIDECAR_URL=http://127.0.0.1:8008
